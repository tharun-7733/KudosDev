# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kudosdev-analytics?retryWrites=true&w=majority

# Server port
PORT=4000

# Node environment
NODE_ENV=development

# CORS origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Rate limiter
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
